centralRegion=8

for fileWT in $(ls -1 *scan_WT*range4*text.mtx);
do
    
    fileGAnmut2=$( echo $fileWT | sed "s/scan_WT/scan_GAnmut2/g")
    fileGAnmut4=$( echo $fileWT | sed "s/scan_WT/scan_GAnmut4/g")
    fileGAnmut6=$( echo $fileWT | sed "s/scan_WT/scan_GAnmut6/g")
    echo $fileWT $fileGAnmut2 $fileGAnmut4 $fileGAnmut6
    echo
    
    outFile=$(echo ${fileWT%_text.mtx}_centralRegion_${centralRegion}pixels_heatmaps.pdf | sed "s/WT_//g")
    ls -lrtha ${fileWT} ${fileGAnmut2} ${fileGAnmut4} ${fileGAnmut6}
    
    echo
    awk '{for(i=2;i<=NF;i++){print NR-1,i-2,$i}}' <( awk '{if(NR>1) print $0}' ${fileWT})      > _tmp_matrix_WT
    awk '{for(i=2;i<=NF;i++){print NR-1,i-2,$i}}' <( awk '{if(NR>1) print $0}' ${fileGAnmut2}) > _tmp_matrix_GAnmut2
    awk '{for(i=2;i<=NF;i++){print NR-1,i-2,$i}}' <( awk '{if(NR>1) print $0}' ${fileGAnmut4}) > _tmp_matrix_GAnmut4
    awk '{for(i=2;i<=NF;i++){print NR-1,i-2,$i}}' <( awk '{if(NR>1) print $0}' ${fileGAnmut6}) > _tmp_matrix_GAnmut6    
    head -1 _tmp_matrix_WT
    tail -1 _tmp_matrix_WT    
    size=$(tail -1 _tmp_matrix_WT | awk '{print $1}')
    echo $size
    
    cbmin=$(awk 'BEGIN{min=$3}{if($3<max){min=$3}}END{printf("%.2f",min)}' _tmp_matrix_*)        
    cbmax=$(awk 'BEGIN{max=$3}{if($3>max){max=$3}}END{printf("%.2f",max)}' _tmp_matrix_*)
    echo ${cbmin} ${cbmax}

    cbmin=-1.5
    cbmax=1.5
    echo ${cbmin} ${cbmax}    

    name=$(echo ${fileWT} | sed -e "s/_WT//g" -e "s/_res500_peScan_text\.mtx//g" -e "s/_res250_peScan_text\.mtx//g")
    echo ${fileWT}

    Nloops=$(echo ${fileWT} | sed -e "s/N1/ 1/g" -e "s/N2/ 2/g" -e "s/N3/ 3/g" -e "s/N4/ 4/g" -e "s/N5/ 5/g" -e "s/N6/ 6/g" -e "s/N7/ 7/g" -e "s/N8/ 8/g" -e "s/N9/ 9/g" | awk '{print $2}' | sed "s/_/ /g" | awk '{print $1}')
    echo "Number of loops "$Nloops
    
    xmin=$(echo ${fileWT} | sed -e "s/range/ /g" | awk '{print $2}' | sed "s/_/ /g" | awk '{print "-"$1"kb"}')
    xmax=$(echo ${fileWT} | sed -e "s/range/ /g" | awk '{print $2}' | sed "s/_/ /g" | awk '{print "+"$1"kb"}')
    ymin=$(echo ${fileWT} | sed -e "s/range/ /g" | awk '{print $2}' | sed "s/_/ /g" | awk '{print "-"$1"kb"}')
    ymax=$(echo ${fileWT} | sed -e "s/range/ /g" | awk '{print $2}' | sed "s/_/ /g" | awk '{print "+"$1"kb"}')        
    echo ${xmin} ${xmax} ${ymin} ${ymax}

    bottom=$( head -1 _tmp_matrix_WT | awk '{print $1}')
    low=$(    awk -v s=$size -v c=$centralRegion 'BEGIN{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); print low}')
    high=$(   awk -v s=$size -v c=$centralRegion 'BEGIN{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); print high}')
    top=$(    tail -1 _tmp_matrix_WT | awk '{print $1}')
    echo $bottom $low $high $top
    sed -e "s/XXXhighXXX/${high}/g" -e "s/XXXlowXXX/${low}/g" -e "s/XXXcbminXXX/${cbmin}/g"  -e "s/XXXcbmaxXXX/${cbmax}/g" -e "s/XXXxminXXX/${xmin}/g" -e "s/XXXxmaxXXX/${xmax}/g" -e "s/XXXyminXXX/${ymin}/g" -e "s/XXXymaxXXX/${ymax}/g" -e "s/XXXsizeXXX/${size}/g" -e "s/XXXNXXX/${Nloops}/g" ../scripts/03a_plot_contact_matrix.gp | gnuplot

    bash ~/TOOLS/ps2pdf.sh
    mv heatmap_map.pdf ${outFile}
    
    # Quantify differences
    rm -fvr _tmp.txt
    wc -l _tmp_matrix_*

    awk -v s=$size -v c=$centralRegion '{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); if((low<($1+1) && ($1+1)<=high) && (low<($2+1) && ($2+1)<=high)){print "WT",$3}}'  _tmp_matrix_WT >> _tmp.txt
    awk -v s=$size -v c=$centralRegion '{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); if((low<($1+1) && ($1+1)<=high) && (low<($2+1) && ($2+1)<=high)){print "GAnmut2",$3}}'  _tmp_matrix_GAnmut2 >> _tmp.txt
    awk -v s=$size -v c=$centralRegion '{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); if((low<($1+1) && ($1+1)<=high) && (low<($2+1) && ($2+1)<=high)){print "GAnmut4",$3}}'  _tmp_matrix_GAnmut4 >> _tmp.txt
    awk -v s=$size -v c=$centralRegion '{low=(s+1)/2-int(c/2); high=(s+1)/2+int(c/2); if((low<($1+1) && ($1+1)<=high) && (low<($2+1) && ($2+1)<=high)){print "GAnmut6",$3}}'  _tmp_matrix_GAnmut6 >> _tmp.txt    

    #cat _tmp.txt
    wc -l _tmp.txt
    cp _tmp.txt ${outFile%.pdf}_data.txt 

done
